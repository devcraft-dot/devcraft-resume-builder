APP_NAME=resume-builder

# Neon PostgreSQL pooled connection string
DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.us-east-2.aws.neon.tech/resume_builder?sslmode=require

# OpenAI (GPT-5.4 / GPT-5.4-mini)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=

# DeepSeek (leave empty to disable)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Google Drive — paste the full JSON of your OAuth token (single line)
GOOGLE_DRIVE_FOLDER_ID=
DRIVE_TOKEN_JSON=

# Google Sheets — paste the full JSON of your service-account key (single line)
GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_WORKSHEET=Sheet1
